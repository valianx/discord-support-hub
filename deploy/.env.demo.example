# Real Discord credentials for the test/demo stack.
#
# Copy this file to deploy/.env.demo, fill in real values, then run:
#   docker compose --env-file deploy/.env.demo -f deploy/docker-compose.test.yml up -d --build
#
# deploy/.env.demo is git-ignored — your bot token never touches git.
# See docs/test-guild-setup.md for how to create the bot, guild, role, and category.

# --- REQUIRED for real provisioning ---
# Bot token from your Discord application (Bot tab).
DISCORD_BOT_TOKEN=
# Test server (guild) id.
DISCORD_GUILD_ID=
# Agent role id in that guild — MUST differ from the guild id (boot guard).
DISCORD_AGENT_ROLE_ID=
# Category channel id to create spaces under.
DISCORD_CATEGORY_ID=

# --- OAuth2 (only needed to onboard collaborators via "Connect with Discord") ---
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
# Must match a redirect URL registered in your Discord app (default points at the local stack):
DISCORD_OAUTH_REDIRECT_URL=http://localhost:3000/v1/oauth/discord/callback

# --- Optional ---
# Your brand suffix on agent nicknames, e.g. "- Acme". Empty = marking off.
AGENT_NICKNAME_SUFFIX=
# Overrides (the test defaults are fine for a local demo):
# ENCRYPTION_KEY=      # openssl rand -base64 32
# OAUTH_HMAC_SECRET=   # openssl rand -hex 32
