# discord-support-hub — environment variable reference
# Copy this file to .env and fill in real values. Never commit .env.
# All required values must be set; the service fails loudly at startup if they are missing.

# ── HTTP server ──────────────────────────────────────────────────────────────
HTTP_ADDR=:8080

# ── PostgreSQL (required) ─────────────────────────────────────────────────────
# Full DSN including host, port, database, user, password, and sslmode.
# sslmode=disable is acceptable for local development only.
# Production MUST use sslmode=require (or sslmode=verify-full for mutual TLS).
# Never use sslmode=disable outside a trusted local environment.
POSTGRES_DSN=postgres://hub:change-me@localhost:5432/discord_support_hub?sslmode=disable

# ── Valkey / Redis ────────────────────────────────────────────────────────────
# Cache + coordination only — never source of truth.
VALKEY_ADDR=localhost:6379
VALKEY_PASSWORD=
VALKEY_DB=0

# ── Discord bot (required) ────────────────────────────────────────────────────
# The bot token is NEVER persisted or logged (NFR-6). Set here and nowhere else.
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# The Discord guild (server) the bot manages.
DISCORD_GUILD_ID=your-guild-id-here

# The Discord role ID that all agents receive (category-level VIEW_CHANNEL).
DISCORD_AGENT_ROLE_ID=your-agent-role-id-here

# The default Discord category ID for new spaces (channels).
DISCORD_CATEGORY_ID=your-category-id-here

# ── Discord OAuth2 ────────────────────────────────────────────────────────────
# Used for the "Connect with Discord" guilds.join flow (FR-22).
DISCORD_OAUTH_CLIENT_ID=your-oauth-client-id-here
DISCORD_OAUTH_CLIENT_SECRET=your-oauth-client-secret-here
DISCORD_OAUTH_REDIRECT_URL=https://your-hub-domain.example.com/v1/oauth/discord/callback

# ── Encryption (required for OAuth2 token storage) ───────────────────────────
# AES-256-GCM key, base64-encoded 32 bytes. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Empty = no cross-origin requests.
# Never use "*" with credentials. Add the POC frontend origin here when built.
CORS_ALLOWED_ORIGINS=

# ── Optional features ─────────────────────────────────────────────────────────
# Agent nickname suffix (FR-24). Empty = feature disabled (default).
# When set (e.g. " [Support]"), the suffix is appended to agent nicknames via
# GuildMemberNickname on the marking queue.
AGENT_NICKNAME_SUFFIX=

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10

# ── Reconciler sweep (M5) ─────────────────────────────────────────────────────
# Cron expression for the scheduled full-guild reconcile sweep.
# Default: every 5 minutes. Set to "" to disable the scheduled sweep.
# The reconciler is Postgres-authoritative: any Discord access not in Postgres is revoked.
RECONCILE_SWEEP_CRON=*/5 * * * *
