# Optional: override the default hub base URL at build time.
# The API key is NEVER stored in env files — it is supplied at runtime via the Settings dialog.
#
# For local development with the Vite dev proxy (recommended):
#   leave this unset — the proxy forwards /v1 → http://localhost:8080
#
# For a deployed instance pointing at a remote hub:
#   VITE_HUB_BASE_URL=https://hub.example.com
VITE_HUB_BASE_URL=
